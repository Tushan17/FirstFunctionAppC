{
  "info": {
    "name": "XML Upload Function Tests",
    "description": "Test collection for Azure Function XML Upload with JWT authentication.\nRun '01 Get Token - Valid Credentials' first — it saves the token to {{jwtToken}}.\nAll protected requests inherit the Bearer token from the collection-level auth.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwtToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:7222",
      "type": "string"
    },
    {
      "key": "apiUsername",
      "value": "admin",
      "type": "string",
      "description": "Must match Api__Username in local.settings.json / Azure app settings"
    },
    {
      "key": "apiPassword",
      "value": "",
      "type": "string",
      "description": "Must match Api__Password in local.settings.json / Azure app settings — fill in before running"
    },
    {
      "key": "jwtToken",
      "value": "",
      "type": "string",
      "description": "Populated automatically by the Get Token request — do not edit manually"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "auth": { "type": "noauth" },
      "item": [
        {
          "name": "01 Get Token - Valid Credentials",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{apiUsername}}\",\n  \"password\": \"{{apiPassword}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/token",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "token"]
            },
            "description": "Obtains a JWT and saves it to {{jwtToken}}. Run this first before any protected request. Expected: 200 OK."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 OK', function() { pm.response.to.have.status(200); });",
                  "pm.test('Token returned and saved', function() {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.token).to.be.a('string').and.not.empty;",
                  "    pm.expect(json.expires).to.be.a('string');",
                  "    pm.collectionVariables.set('jwtToken', json.token);",
                  "});"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "02 Get Token - Invalid Credentials",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{apiUsername}}\",\n  \"password\": \"wrongpassword\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/token",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "token"]
            },
            "description": "Sends an incorrect password. Expected: 401 Unauthorized."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 401 Unauthorized', function() { pm.response.to.have.status(401); });",
                  "pm.test('Success is false', function() { pm.expect(pm.response.json().success).to.be.false; });",
                  "pm.test('Message mentions invalid credentials', function() {",
                  "    pm.expect(pm.response.json().message.toLowerCase()).to.include('invalid');",
                  "});"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "03 Get Token - Missing Fields",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/token",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "token"]
            },
            "description": "Sends an empty username and no password. Expected: 400 Bad Request."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 400 Bad Request', function() { pm.response.to.have.status(400); });",
                  "pm.test('Success is false', function() { pm.expect(pm.response.json().success).to.be.false; });",
                  "pm.test('Message mentions required fields', function() {",
                  "    pm.expect(pm.response.json().message.toLowerCase()).to.include('required');",
                  "});"
                ]
              }
            }
          ],
          "response": []
        }
      ]
    },
    {
      "name": "Health Check",
      "item": [
        {
          "name": "Function1 - Authenticated",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/Function1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "Function1"]
            },
            "description": "Health check using a valid JWT from {{jwtToken}}. Expected: 200 OK with Welcome message."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200 OK', function() { pm.response.to.have.status(200); });",
                  "pm.test('Welcome message returned', function() { pm.expect(pm.response.text()).to.include('Welcome'); });"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Function1 - No Token",
          "auth": { "type": "noauth" },
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/Function1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "Function1"]
            },
            "description": "Health check with no Authorization header. Expected: 401 Unauthorized."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 401 Unauthorized', function() { pm.response.to.have.status(401); });",
                  "pm.test('Success is false', function() { pm.expect(pm.response.json().success).to.be.false; });"
                ]
              }
            }
          ],
          "response": []
        }
      ]
    },
